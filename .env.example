# ============================================
# CONFIGURATION - ESPACE MEMBRES FGBMFI PARIS
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Ne JAMAIS committer le fichier ".env" réel.
# ============================================

# --- Général ---
NODE_ENV=production
PORT=3000
APP_URL=https://espace-membres-fgbmfi.onrender.com

# --- Sécurité des sessions ---
# Générez une chaîne aléatoire longue, ex: openssl rand -hex 32
JWT_SECRET=CHANGEZ_MOI_avec_une_chaine_aleatoire_longue
SESSION_DURATION_HOURS=2

# --- Signature des URL temporaires du PDF ---
PDF_TOKEN_SECRET=CHANGEZ_MOI_aussi_avec_une_chaine_aleatoire_differente
PDF_TOKEN_TTL_SECONDS=90

# --- Envoi de SMS ---
# Mode "mock" : aucun SMS n'est réellement envoyé, le code s'affiche
# dans les logs serveur et dans l'admin (utile pour tester sans Twilio).
# Mode "twilio" : envoi réel via Twilio.
SMS_PROVIDER=mock

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Règles anti-robot / limites OTP ---
OTP_MAX_PAR_JOUR=3
OTP_DELAI_MIN_SECONDES=60
OTP_VALIDITE_MINUTES=5
OTP_TENTATIVES_MAX=3
OTP_BLOCAGE_MINUTES=30

# --- Administration ---
# Compte super-admin initial, créé via "npm run init-admin"
ADMIN_EMAIL=admin@fgbmfi-paris.org

# --- Géoblocage (optionnel) ---
# Liste de codes pays ISO à bloquer, séparés par des virgules. Vide = désactivé.
PAYS_BLOQUES=RU,CN

# --- Liens externes par défaut (modifiables ensuite dans l'admin) ---
SITE_OFFICIEL_URL=https://fgbmfi-paris.org
PRESENTATION_URL=https://fgbmfi-paris.netlify.app
